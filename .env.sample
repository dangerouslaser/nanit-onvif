# General configuration --------------------------------------------------------

# Writeable directory where all the files will be stored (default: ./data)
# NANIT_DATA_DIR=/app/data

# Default value: info
# Allowed values: trace | debug | info | warn | error | fatal | panic
# NANIT_LOG_LEVEL=debug

# Session file (optional)
# Stores state between runs.
#
# Warning: The file contains sensitive information (auth tokens, etc.).
# NANIT_SESSION_FILE=data/session.json

# Nanit refresh token (optional, alternative to web login)
# NANIT_REFRESH_TOKEN=

# RTMP server ------------------------------------------------------------------

# Enable integrated RTMP server (default: true)
# NANIT_RTMP_ENABLED=true

# Address, path, and key under which is this app reachable from the cam
# Final URL will be rtmp://<NANIT_RTMP_ADDR><NANIT_RTMP_PATH>/<NANIT_RTMP_KEY>
# Note: You cannot use your 127.0.0.1 here, it has to be reachable from the cam.
#  Also pay attention to the port if you are port forwarding it in Docker.
# NANIT_RTMP_ADDR=192.168.3.234:1935

# default: /local
# NANIT_RTMP_PATH=/camera

# default: Nanit's baby UID
# NANIT_RTMP_KEY=abc123

# RTSP server ------------------------------------------------------------------

# Enable RTSP server (default: true)
# Serves H.264 video + AAC audio from the camera's RTMP stream
# NANIT_RTSP_ENABLED=true

# RTSP listen address (default: :8554)
# NANIT_RTSP_ADDR=:8554

# ONVIF server -----------------------------------------------------------------

# Enable ONVIF server for NVR discovery (default: true)
# NANIT_ONVIF_ENABLED=true

# ONVIF listen address (default: :8089)
# NANIT_ONVIF_ADDR=:8089

# ONVIF authentication credentials (optional, recommended)
# When set, clients must authenticate to access ONVIF services
# NANIT_ONVIF_USERNAME=admin
# NANIT_ONVIF_PASSWORD=changeme

# ONVIF events (PullPoint) — exposes motion/sound as ONVIF events that NVRs
# like Frigate, BlueIris, UniFi Protect, and HA Generic Camera can consume.
# Default: true.
# NANIT_ONVIF_EVENTS=true

# How long motion/sound stays "active" after a REST-polled event, in seconds
# (default: 30). Websocket sensor alerts override this and clear immediately
# on their own false signal.
# NANIT_ONVIF_EVENT_HOLD=30

# Web UI -----------------------------------------------------------------------

# Enable web dashboard (default: true)
# Provides login, camera status, and sensor monitoring at http://server:8080
# NANIT_WEB_ENABLED=true

# Web UI listen address (default: :8080)
# NANIT_WEB_ADDR=:8080

# MQTT -------------------------------------------------------------------------

# Enable MQTT integration for reading sensors data (default: false)
# NANIT_MQTT_ENABLED=true

# MQTT broker host (required if enabled)
# Examples:
# - Plain TCP: tcp://iot.eclipse.org:1883
# - Websocket: ws://my.mqtt.local or wss://my.secure.mqtt.local
# NANIT_MQTT_BROKER_URL=

# Credentials for MQTT broker (optional)
# NANIT_MQTT_USERNAME=
# NANIT_MQTT_PASSWORD=

# Client ID (default: nanit)
# NANIT_MQTT_CLIENT_ID=mynanit

# Topic prefix (default: nanit)
# NANIT_MQTT_PREFIX=mynanit

# Home Assistant MQTT discovery (default: false). Publishes retained
# homeassistant/{component}/{baby}/{entity}/config topics so HA auto-creates
# sensors, binary_sensors, switches, and numbers grouped per baby.
# NANIT_MQTT_HA_DISCOVERY=true

# Discovery topic prefix (default: homeassistant — matches HA default).
# NANIT_MQTT_HA_DISCOVERY_PREFIX=homeassistant

# Enable inbound command topics (default: false). When enabled, publishing
# to nanit/babies/{uid}/set/{field} sends the corresponding control or
# settings write to the camera. Supported fields:
#   night_light_on, night_light_timeout, volume, mic_mute_on,
#   sleep_mode, status_light_on, night_vision
# With HA discovery enabled, writable fields become switch/number entities.
# NANIT_MQTT_COMMANDS=true

# Event Polling ----------------------------------------------------------------

# While Nanit doesn't provide a stream of events to subscribe to, you can poll
# the /babies/{baby_uid}/messages endpoint to retrieve the latest event messages

# Enable events polling
# NANIT_EVENTS_POLLING=true

# Interval in seconds at which to poll for new event messages (default: 30)
# NANIT_EVENTS_POLLING_INTERVAL=20

# Time in seconds after which to disregard event messages (default: 300)
# NANIT_EVENTS_MESSAGE_TIMEOUT=300
